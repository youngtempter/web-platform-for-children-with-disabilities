# ==============================================================================
# QazEdu Special - Frontend Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values (if needed)
# ==============================================================================

# ------------------------------------------------------------------------------
# API URL (Optional)
# ------------------------------------------------------------------------------
# By default, the Vite dev server proxies /api requests to localhost:8000
# Only set this if you need to connect to a different backend URL
# 
# For local development with proxy (default, no changes needed):
# VITE_API_URL=
#
# For direct connection to backend (e.g., production):
# VITE_API_URL=https://api.qazedu.example.com
#
# For Docker or different local port:
# VITE_API_URL=http://localhost:8000

VITE_API_URL=
