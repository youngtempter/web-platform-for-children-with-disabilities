# ==============================================================================
# QazEdu Special - Backend Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# For local development with SQLite (default, no setup needed):
DATABASE_URL=sqlite:///./qazedu.db

# For PostgreSQL (production or Docker):
# DATABASE_URL=postgresql://user:password@localhost:5432/qazedu

# ------------------------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------------------------
# IMPORTANT: Generate a secure key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=please-change-me-in-your-local-env

# JWT algorithm (default: HS256)
ALGORITHM=HS256

# Token expiration in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ------------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------------------------------------------
# Comma-separated list of allowed origins
# For local development:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ------------------------------------------------------------------------------
# ADMIN SEED ACCOUNT
# ------------------------------------------------------------------------------
# Optional credentials for the initial admin user.
# Admin will be created on startup ONLY if ALL of the following are set:
# ADMIN_EMAIL, ADMIN_PASSWORD, ADMIN_FIRST_NAME, ADMIN_LAST_NAME
# (Recommended: set only in secure environments, not in public repos)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_FIRST_NAME=
# ADMIN_LAST_NAME=

# ------------------------------------------------------------------------------
# AI ASSISTANT (Optional)
# ------------------------------------------------------------------------------
# Google Gemini API key for AI chat functionality
# Get your key at: https://aistudio.google.com/apikey
# Leave empty to disable AI chat feature
GEMINI_API_KEY=
